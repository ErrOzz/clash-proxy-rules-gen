mixed-port: 7890
allow-lan: false
mode: rule
log-level: info
# external-controller: 127.0.0.1:9090

# --- GeoX Data Sources ---
geodata-mode: false
geox-url:
  geoip: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geoip.dat"
  geosite: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geosite.dat"
  mmdb: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/country.mmdb"

geo-auto-update: true
geo-update-interval: 24 # in hours

dns:
  enable: true
  ipv6: false
  listen: 0.0.0.0:53
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - '*.lan'
    - '*.local'
  nameserver:
    - https://dns.google/dns-query
    - https://cloudflare-dns.com/dns-query
    - https://dns.adguard-dns.com/dns-query # Блокирует рекламу
  fallback:
    - https://dns.quad9.net/dns-query
    - tls://1.1.1.1:853
  use-system-hosts: true
  default-nameserver:
    - 8.8.8.8
    - 1.1.1.1

  nameserver-policy:
    '+.ru':
      - https://dns.yandex.ru/dns-query
      - 77.88.8.8
    '+.su':
      - https://dns.yandex.ru/dns-query
      - 77.88.8.8
    '+.xn--p1ai': # This is .рф
      - https://dns.yandex.ru/dns-query
      - 77.88.8.8

proxies:
  # --- Panel Proxies ---
  {% for proxy in panel_proxies -%}
  - {{ proxy | to_yaml | indent(4) }}
  {% endfor %}
  
  # --- External Providers ---
  {% for provider, proxies in providers.items() -%}
  {% for proxy in proxies -%}
  - {{ proxy | to_yaml | indent(4) }}
  {% endfor -%}
  {% endfor %}

proxy-groups:
  # --- 1. HIDDEN AUTO GROUPS (Flat Logic) ---
  - name: ♻️ Auto (Public First)
    type: fallback
    hidden: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      {% if providers|length > 0 %}
      - 🌐 Public Providers
      {% endif %}
      - 🏠 Private Server

  - name: ♻️ Auto (Private First)
    type: fallback
    hidden: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      - 🏠 Private Server
      {% if providers|length > 0 %}
      - 🌐 Public Providers
      {% endif %}

  # --- 2. MAIN ROUTING GROUPS (Top of the UI) ---
  - name: 🚀 PROXY
    type: select
    proxies:
      - ♻️ Auto (Public First)
      - ♻️ Auto (Private First)
      {% if providers|length > 0 %}
      - 🌐 Public Providers
      {% endif %}
      - 🏠 Private Server

  - name: 🐟 OTHER
    type: select
    proxies:
      - DIRECT
      - 🚀 PROXY

  # --- 3. SPECIFIC NODE SELECTORS (Middle of the UI) ---
  {% for provider, proxies in providers.items() %}
  - name: 🗂️ {{ provider }}
    type: select
    proxies:
      {% for proxy in proxies -%}
      - "{{ proxy.name }}"
      {% endfor %}
  {% endfor %}

  # --- 4. RARE SETTINGS & ROUTING (Bottom of the UI) ---
  - name: ▶️ YouTube
    type: select
    proxies:
      - ♻️ Auto (Public First)
      - 🏠 Private Server
      {% if providers|length > 0 %}
      - 🌐 Public Providers
      {% endif %}

  - name: 🤖 AI & Dev
    type: select
    proxies:
      - ♻️ Auto (Private First)
      - 🏠 Private Server
      {% if providers|length > 0 %}
      - 🌐 Public Providers
      {% endif %}

  {% if providers|length > 0 %}
  - name: 🌐 Public Providers
    type: select
    proxies:
      {% for provider in providers.keys() -%}
      - 🗂️ {{ provider }}
      {% endfor %}
  {% endif %}

  - name: 🏠 Private Server
    type: select
    proxies:
      {% for proxy in panel_proxies -%}
      - "{{ proxy.name }}"
      {% endfor %}
#
rule-providers:
  proxy_domains:
    behavior: classical
    type: http
    url: "{{ rule_provider_url }}"
    interval: 3600 # in seconds
    path: ./proxy_domains.yaml # Lockal rule file name

rules:
  - IP-CIDR,10.0.0.0/24,DIRECT
  - IP-CIDR,100.64.0.0/22,DIRECT
  - IP-CIDR,172.16.0.0/12,DIRECT
  - IP-CIDR,192.168.0.0/16,DIRECT
  - DOMAIN-SUFFIX,local,DIRECT
  - DOMAIN-SUFFIX,localhost,DIRECT

  # Messengers
  {%- set messengers = [
      'telegram',
      'whatsapp',
      'signal',
      'discord',
      'messenger',
      'slack'
  ] %}
  {% for app in messengers -%}
  - GEOSITE,{{ app }},🚀 PROXY
  {% endfor -%}

  # social media and content platforms
  {% set social = [
      'facebook', 
      'instagram', 
      'linkedin', 
      'twitter', 
      'google-play',
      'soundcloud',
      'tiktok' 
  ] %}
  {% for app in social -%}
  - GEOSITE,{{ app }},🚀 PROXY
  {% endfor -%}

  # YouTube Routing (Goes to its specific group)
  - GEOSITE,youtube,▶️ YouTube

  # ai and developer platforms
  {% set ai_dev = [
      'category-ai-!cn', 
      'github'
  ] %}
  {% for app in ai_dev -%}
  - GEOSITE,{{ app }},🤖 AI & Dev
  {% endfor %}
  - DOMAIN-SUFFIX,clients6.google.com,🤖 AI & Dev

  # --- CRITICAL: GEOIP Rules for Direct IP Connections ---
  - GEOIP,telegram,🚀 PROXY,no-resolve
  # 'facebook' covers WhatsApp, Instagram, and Messenger IPs
  - GEOIP,facebook,🚀 PROXY,no-resolve
  - GEOIP,twitter,🚀 PROXY,no-resolve

  - RULE-SET,proxy_domains,🚀 PROXY

# --- Light Regional Rules for Russia ---
  - DOMAIN-SUFFIX,ru,DIRECT
  - DOMAIN-SUFFIX,su,DIRECT
  - DOMAIN-SUFFIX,xn--p1ai,DIRECT # Zone .рф in punycode

  - MATCH,🐟 OTHER