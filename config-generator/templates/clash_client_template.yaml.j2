mixed-port: 7890
allow-lan: false
mode: rule
log-level: info
# external-controller: 127.0.0.1:9090

# --- GeoX Data Sources ---
geodata-mode: false
geox-url:
  geoip: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geoip.dat"
  geosite: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/geosite.dat"
  mmdb: "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@release/country.mmdb"

geo-auto-update: true
geo-update-interval: 24 # in hours

dns:
  enable: true
  ipv6: false
  listen: 0.0.0.0:53
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter:
    - '*.lan'
    - '*.local'
  nameserver:
    - https://dns.google/dns-query
    - https://cloudflare-dns.com/dns-query
    - https://dns.adguard-dns.com/dns-query # Блокирует рекламу
  fallback:
    - https://dns.quad9.net/dns-query
    - tls://1.1.1.1:853
  use-system-hosts: true
  default-nameserver:
    - 8.8.8.8
    - 1.1.1.1

  nameserver-policy:
    '+.ru':
      - https://dns.yandex.ru/dns-query
      - 77.88.8.8
    '+.su':
      - https://dns.yandex.ru/dns-query
      - 77.88.8.8
    '+.xn--p1ai': # This is .рф
      - https://dns.yandex.ru/dns-query
      - 77.88.8.8

proxies:
  # Panel Proxy
  - {{ panel_proxy | to_yaml | indent(4) }}
  
  # Single Nodes
  {% for proxy in single_nodes -%}
  - {{ proxy | to_yaml | indent(4) }}
  {% endfor %}
  
  # Multi Nodes
  {% for proxy in multi_nodes -%}
  - {{ proxy | to_yaml | indent(4) }}
  {% endfor %}

proxy-groups:
  # --- 1. HIDDEN AUTO GROUPS (Multi-nodes Fallback) ---
  {% if multi_nodes|length > 0 %}
  - name: ♻️ {{ provider_multi_name }} Auto
    type: fallback
    hidden: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      {% for proxy in multi_nodes -%}
      - "{{ proxy.name }}"
      {% endfor %}
  {% endif %}

  # --- 2. HIDDEN AUTO GROUPS (Cross-Subscription Fallback) ---
  {% if single_nodes|length > 0 and multi_nodes|length > 0 %}
  - name: ♻️ Auto ({{ provider_multi_name }} ➔ {{ provider_single_name }})
    type: fallback
    hidden: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      - 🗂️ {{ provider_multi_name }}
      - "{{ single_nodes[0].name }}"

  - name: ♻️ Auto ({{ provider_single_name }} ➔ {{ provider_multi_name }})
    type: fallback
    hidden: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      - "{{ single_nodes[0].name }}"
      - 🗂️ {{ provider_multi_name }}
  {% endif %}

  # --- 3. GLOBAL HIDDEN FALLBACKS (Panel Protection) ---
  - name: ♻️ Auto (Backup First)
    type: fallback
    hidden: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      {% if single_nodes|length > 0 or multi_nodes|length > 0 %}
      - 🛠️ External Choice
      {% endif %}
      - "{{ panel_proxy.name }}"

  - name: ♻️ Auto (Panel First)
    type: fallback
    hidden: true
    url: 'http://www.gstatic.com/generate_204'
    interval: 300
    proxies:
      - "{{ panel_proxy.name }}"
      {% if single_nodes|length > 0 or multi_nodes|length > 0 %}
      - 🛠️ External Choice
      {% endif %}

  # --- 4. MANUAL SELECTORS (Level 1 & 2) ---
  {% if multi_nodes|length > 0 %}
  - name: 🗂️ {{ provider_multi_name }}
    type: select
    proxies:
      - ♻️ {{ provider_multi_name }} Auto
      {% for proxy in multi_nodes -%}
      - "{{ proxy.name }}"
      {% endfor %}
  {% endif %}

  {% if single_nodes|length > 0 or multi_nodes|length > 0 %}
  - name: 🛠️ External Choice
    type: select
    proxies:
      {% if single_nodes|length > 0 and multi_nodes|length > 0 %}
      - ♻️ Auto ({{ provider_multi_name }} ➔ {{ provider_single_name }})
      - ♻️ Auto ({{ provider_single_name }} ➔ {{ provider_multi_name }})
      {% elif multi_nodes|length > 0 %}
      - 🗂️ {{ provider_multi_name }}
      {% elif single_nodes|length > 0 %}
      - "{{ single_nodes[0].name }}"
      {% endif %}
  {% endif %}

  # --- 5. MAIN ROUTING GROUPS (UI) ---
  - name: 🚀 PROXY
    type: select
    proxies:
      - ♻️ Auto (Backup First)
      - ♻️ Auto (Panel First)
      - "{{ panel_proxy.name }}"
      {% if single_nodes|length > 0 or multi_nodes|length > 0 %}
      - 🛠️ External Choice
      {% endif %}

  - name: 🐟 OTHER
    type: select
    proxies:
      - DIRECT
      - 🚀 PROXY

  - name: ▶️ YouTube
    type: select
    proxies:
      - ♻️ Auto (Backup First)
      - "{{ panel_proxy.name }}"
      {% if single_nodes|length > 0 or multi_nodes|length > 0 %}
      - 🛠️ External Choice
      {% endif %}

  - name: 🤖 AI & Dev
    type: select
    proxies:
      - ♻️ Auto (Panel First)
      - "{{ panel_proxy.name }}"
      {% if single_nodes|length > 0 or multi_nodes|length > 0 %}
      - 🛠️ External Choice
      {% endif %}
#
rule-providers:
  proxy_domains:
    behavior: classical
    type: http
    url: "{{ rule_provider_url }}"
    interval: 3600 # in seconds
    path: ./proxy_domains.yaml # Lockal rule file name

rules:
  - IP-CIDR,10.0.0.0/24,DIRECT
  - IP-CIDR,100.64.0.0/22,DIRECT
  - IP-CIDR,172.16.0.0/12,DIRECT
  - IP-CIDR,192.168.0.0/16,DIRECT
  - DOMAIN-SUFFIX,local,DIRECT
  - DOMAIN-SUFFIX,localhost,DIRECT

  # Messengers
  {%- set messengers = [
      'telegram',
      'whatsapp',
      'signal',
      'discord',
      'messenger',
      'slack'
  ] %}
  {% for app in messengers -%}
  - GEOSITE,{{ app }},🚀 PROXY
  {% endfor -%}

  # social media and content platforms
  {% set social = [
      'facebook', 
      'instagram', 
      'linkedin', 
      'twitter', 
      'google-play',
      'tiktok' 
  ] %}
  {% for app in social -%}
  - GEOSITE,{{ app }},🚀 PROXY
  {% endfor -%}

  # YouTube Routing (Goes to its specific group)
  - GEOSITE,youtube,▶️ YouTube

  # ai and developer platforms
  {% set ai_dev = [
      'category-ai-!cn', 
      'github'
  ] %}
  {% for app in ai_dev -%}
  - GEOSITE,{{ app }},🤖 AI & Dev
  {% endfor %}

  # --- CRITICAL: GEOIP Rules for Direct IP Connections ---
  - GEOIP,telegram,🚀 PROXY,no-resolve
  # 'facebook' covers WhatsApp, Instagram, and Messenger IPs
  - GEOIP,facebook,🚀 PROXY,no-resolve
  - GEOIP,twitter,🚀 PROXY,no-resolve

  - RULE-SET,proxy_domains,🚀 PROXY

# --- Light Regional Rules for Russia ---
  - DOMAIN-SUFFIX,ru,DIRECT
  - DOMAIN-SUFFIX,su,DIRECT
  - DOMAIN-SUFFIX,xn--p1ai,DIRECT # Zone .рф in punycode

  - MATCH,🐟 OTHER